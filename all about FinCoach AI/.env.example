# ──────────────────────────────────────────────────────────────
# FinCoach — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env to version control.
# ──────────────────────────────────────────────────────────────

# IBM Cloud API key (cloud.ibm.com → Manage → Access → API Keys)
IBM_WATSONX_API_KEY=your-ibm-cloud-api-key-here

# watsonx.ai Project ID (watsonx.ai → Project → Manage → General)
IBM_WATSONX_PROJECT_ID=your-watsonx-project-id-here

# watsonx.ai regional endpoint
# Options: us-south | eu-de | eu-gb | jp-tok | au-syd
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite model to use
# Recommended:
#   ibm/granite-3-8b-instruct        — fast, great for chat (default)
#   ibm/granite-13b-chat-v2          — more nuanced, slightly slower
#   meta-llama/llama-3-70b-instruct  — best quality, slowest
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Flask session secret — change to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string
